
&НаКлиенте
Процедура УвеличитьКоличество(Команда)
	
	СтрокиДляОбработки = Элементы.Работы.ПолучитьСтрокиДляОбработки();
	
	Для Каждого ИдентификаторСтроки Из СтрокиДляОбработки Цикл
		
		ДанныеСтроки = Элементы.Работы.ДанныеСтроки(ИдентификаторСтроки);
		ДанныеСтроки.Количество = ДанныеСтроки.Количество + 1;
		ДанныеСтроки.Сумма = ДанныеСтроки.Количество * ДанныеСтроки.Цена;
		
	КонецЦикла;

КонецПроцедуры
