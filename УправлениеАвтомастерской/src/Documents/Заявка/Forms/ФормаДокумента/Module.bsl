
&НаКлиенте
Процедура Печать(Команда)
	ПредупреждениеАсинх("Что-то напечатали");
КонецПроцедуры

&НаКлиенте
Процедура СоздатьВыполнениеРабот(Команда)
	
	Если Объект.Ссылка.Пустая() Тогда
		ПредупреждениеАсинх("Сначала запишите документ");
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Основание", Объект.Ссылка);
	
	ОткрытьФорму("Документ.ВыполнениеРабот.ФормаОбъекта", ПараметрыФормы);

КонецПроцедуры
